{
    "openapi": "3.0.0",
    "info": {
        "title": "API Contacts",
        "version": "1.0"
    },
    "paths": {
        "/api/contacts": {
            "get": {
                "tags": [
                    "Contact all"
                ],
                "summary": "Get All contacts",
                "description": "Return all contacts",
                "operationId": "e9270e1058a41908e2d7f1e41077a8af",
                "responses": {
                    "200": {
                        "description": "Contact found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "example": "69ab85ce68ca5"
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "João Silva"
                                        },
                                        "email": {
                                            "type": "string",
                                            "example": "joao@email.com"
                                        },
                                        "phone": {
                                            "type": "string",
                                            "example": "11999999999"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Contacts Create"
                ],
                "summary": "New Contact",
                "operationId": "4de38e2d3da335d903194f1f1aa2c0f3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "phone"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "João"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "joao@email.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "119999999"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    }
                }
            }
        },
        "/api/contacts/{id}": {
            "get": {
                "tags": [
                    "Contact find"
                ],
                "summary": "Find by ID",
                "description": "Return contact",
                "operationId": "3131f75778e261f721e04f31e1fd2ed2",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID contact",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "69ab85ce68ca5"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Contact found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "string",
                                            "example": "69ab85ce68ca5"
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "João Silva"
                                        },
                                        "email": {
                                            "type": "string",
                                            "example": "joao@email.com"
                                        },
                                        "phone": {
                                            "type": "string",
                                            "example": "11999999999"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Contato não encontrado"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Delete contact"
                ],
                "summary": "Delete by ID",
                "description": "Delete contact",
                "operationId": "16d9096919116d2c92b50b63b60f702c",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID contact",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "69ab85ce68ca5"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Contact not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Contact deleted"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Contact not found"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Contacts Create",
            "description": "Contacts Create"
        },
        {
            "name": "Contact find",
            "description": "Contact find"
        },
        {
            "name": "Contact all",
            "description": "Contact all"
        },
        {
            "name": "Delete contact",
            "description": "Delete contact"
        }
    ]
}